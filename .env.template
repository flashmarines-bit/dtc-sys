# ============================================================
# DTC System — Environment Variables Template
# Copy to .env.production and fill in the values
# ============================================================

# Database
DB_NAME=dtc_production
DB_USER=dtc_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=postgres
DB_PORT=5432

# JWT
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_SECRET_KEY
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Supabase (dev only)
Supabase__Url=https://YOUR_PROJECT.supabase.co
Supabase__ServiceKey=YOUR_SERVICE_KEY
Supabase__StorageBucket=dtc-storage

# Storage
Storage__Provider=minio
Storage__Minio__Endpoint=minio:9000
Storage__Minio__AccessKey=CHANGE_ME
Storage__Minio__SecretKey=CHANGE_ME_STRONG_SECRET
Storage__Minio__Bucket=dtc-storage
Storage__Minio__UseSSL=false

# Email SMTP
Email__SmtpServer=smtp.gmail.com
Email__SmtpPort=587
Email__SenderEmail=your@email.com
Email__SenderName=DTC System
Email__AppPassword=YOUR_APP_PASSWORD

# OCR Service
OcrService__BaseUrl=http://ocr:8000

# Notification
Notification__Email__Enabled=true
Notification__InApp__Enabled=true
Notification__Push__Enabled=true
Notification__WA__Enabled=false
Notification__WA__Provider=fonnte
Notification__WA__ApiKey=
Notification__WA__SenderNumber=

# SLA Config (hours)
Sla__UnprocessedHours=4
Sla__PendingReviewHours=8
Sla__ExpiryWarningDays=3

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.com
